# CF Access SaaS App (OIDC provider for the Worker's OAuth flow)
ACCESS_CLIENT_ID=<Copy from "Client ID" in dash>
ACCESS_CLIENT_SECRET=<Copy from "Client secret" in dash>
ACCESS_TOKEN_URL=<Copy from "Token endpoint" in dash>
ACCESS_AUTHORIZATION_URL=<Copy from "Authorization endpoint" in dash>
ACCESS_JWKS_URL=<Copy from "Key endpoint" in dash>

# Cookie encryption (generate with: openssl rand -hex 32)
COOKIE_ENCRYPTION_KEY=

# MCP upstream (the actual MCP server behind the tunnel)
MCP_UPSTREAM_URL=https://your-service.yourdomain.com/mcp

# CF Access Service Token (injected into upstream requests)
SERVICE_CLIENT_ID=<CF Access Service Token Client ID>
SERVICE_CLIENT_SECRET=<CF Access Service Token Client Secret>
